<div class="text-center">
  <h1 class="text-4xl font-bold text-gray-900 mb-8">
    出会いの記録アルバム
  </h1>
  
  <p class="text-xl text-gray-600 mb-8">
    あなたの出会いを写真とメモで記録し、友達とシェアしましょう
  </p>

  <% if user_signed_in? %>
    <div class="bg-white rounded-lg shadow-md p-8 max-w-md mx-auto">
      <h2 class="text-2xl font-semibold text-gray-800 mb-4">
        ようこそ、<%= current_user.email %>さん！
      </h2>
      <p class="text-gray-600 mb-6">
        新しい出会いを記録してみましょう
      </p>
      <button class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">
        新しい出会いを記録
      </button>
    </div>
  <% else %>
    <div class="space-y-4">
      <p class="text-lg text-gray-600">
        ログインして、出会いの記録を始めましょう
      </p>
      <div class="space-x-4">
        <%= link_to "ログイン", new_user_session_path, 
                    class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg text-lg" %>
        <%= link_to "新規登録", new_user_registration_path, 
                    class: "bg-green-500 hover:bg-green-700 text-white font-bold py-3 px-6 rounded-lg text-lg" %>
      </div>
    </div>
  <% end %>
</div>
